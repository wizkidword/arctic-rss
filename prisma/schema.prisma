generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ADMIN
}

enum DefaultView {
  CLASSIC
  CARD
  COMPACT
  RIVER
}

enum DisplayMode {
  MINIMAL
  READER
  THREE_PANE
}

enum ThemePreference {
  SYSTEM
  LIGHT
  HOLIDAY
  ORANGE
  SAND
  DARK
  GREY
}

enum FontSizePreference {
  SMALL
  MEDIUM
  LARGE
}

enum DateFormatPreference {
  DEFAULT
  YYYY_MM_DD
  YYYY_DOT_MM_DD
  YYYY_SLASH_MM_DD
  YYYY_DD_MM
  DD_MM_YYYY
  MM_DD_YYYY
}

enum TimeFormatPreference {
  DEFAULT
  HOUR_24
  HOUR_12
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum ImportEntryStatus {
  PENDING
  ADDED
  SKIPPED
  FAILED
}

enum BulkReadJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum AiAction {
  ARTICLE_SUMMARY
  DAILY_DIGEST
  EXPLAIN_ARTICLE
  SMART_CATEGORY
  SEARCH
}

enum AiDigestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiDigestSection {
  MUST_READ
  SKIM_LATER
}

enum AiOperationStatus {
  RESERVED
  PROCESSING
  COMPLETED
  FAILED
}

enum SmartDigestMatchingMode {
  RULES
  HYBRID_AI
}

enum SmartDigestSourceScope {
  ALL_FEEDS
  FOLDERS
  FEEDS
}

enum SmartDigestCadence {
  DAILY
}

enum SmartDigestStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_NO_MATCHES
  FAILED
}

enum SmartDigestEmailStatus {
  NOT_REQUESTED
  PENDING
  SENT
  FAILED
}

enum DigestRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  passwordHash   String?
  authVersion    Int       @default(0)
  role           Role      @default(USER)
  plan           Plan      @default(FREE)
  aiMonthlyLimit Int       @default(100)
  aiMonthlyUsed  Int       @default(0)
  disabledAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts                Account[]
  sessions                Session[]
  settings                UserSettings?
  folders                 Folder[]
  subscriptions           FeedSubscription[]
  podcastSubscriptions    PodcastSubscription[]
  articleStates           ArticleState[]
  podcastEpisodeStates    PodcastEpisodeState[]
  bulkReadJobs            BulkReadJob[]
  articleCollections      ArticleCollection[]
  aiUsageLogs             AiUsageLog[]
  aiUsagePeriods          AiUsagePeriod[]
  aiOperations            AiOperation[]
  aiDigests               AiDigest[]
  smartDigestRules        SmartDigestRule[]
  smartDigests            SmartDigest[]
  importJobs              ImportJob[]
  bugReports              BugReport[]
  featureSuggestions      FeatureSuggestion[]
  adminAuditLogs          AdminAuditLog[]          @relation("AdminAuditActor")
  planQuota               UserPlanQuota?
  securityEvents          SecurityEvent[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model UserPlanQuota {
  userId                  String   @id
  sourceCount             Int      @default(0)
  enabledSmartDigestCount Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserSettings {
  id                     String               @id @default(cuid())
  userId                 String               @unique
  defaultView            DefaultView          @default(CLASSIC)
  displayMode            DisplayMode          @default(THREE_PANE)
  theme                  ThemePreference      @default(SYSTEM)
  fontSize               FontSizePreference   @default(MEDIUM)
  dateFormat             DateFormatPreference @default(DEFAULT)
  timeFormat             TimeFormatPreference @default(DEFAULT)
  timeZone               String               @default("UTC")
  markReadOnOpen         Boolean              @default(true)
  openLinksInNewTab      Boolean              @default(true)
  aiAutoSummariesEnabled Boolean              @default(false)
  dailyDigestEnabled     Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions    FeedSubscription[]      @relation("FeedSubscriptionFolder")
  smartDigestRules SmartDigestRuleFolder[]

  @@unique([userId, id])
  @@index([userId, sortOrder])
}

model Feed {
  id                     String    @id @default(cuid())
  feedUrl                String    @unique
  siteUrl                String?
  title                  String
  description            String?
  faviconUrl             String?
  language               String?
  lastFetchedAt          DateTime?
  lastSuccessfulFetchAt  DateTime?
  lastFailedAt           DateTime?
  lastError              String?
  nextFetchAt            DateTime  @default(now())
  consecutiveFailures    Int       @default(0)
  etag                   String?
  lastModified           String?
  refreshIntervalMinutes Int       @default(60)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  subscriptions FeedSubscription[]
  articles      Article[]

  @@index([nextFetchAt, id])
}

model FeedSubscription {
  id           String   @id @default(cuid())
  userId       String
  feedId       String
  folderId     String?
  customTitle  String?
  sortOrder    Int      @default(0)
  isMuted      Boolean  @default(false)
  isPaused     Boolean  @default(false)
  subscribedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  feed             Feed                          @relation(fields: [feedId], references: [id], onDelete: Cascade)
  folder           Folder?                       @relation("FeedSubscriptionFolder", fields: [userId, folderId], references: [userId, id], onDelete: Restrict)
  smartDigestRules SmartDigestRuleSubscription[]

  @@unique([userId, feedId])
  @@unique([userId, id])
  @@index([userId, folderId])
}

model Podcast {
  id                     String    @id @default(cuid())
  feedUrl                String    @unique
  siteUrl                String?
  title                  String
  description            String?
  artworkUrl             String?
  author                 String?
  language               String?
  lastFetchedAt          DateTime?
  lastSuccessfulFetchAt  DateTime?
  lastFailedAt           DateTime?
  lastError              String?
  nextFetchAt            DateTime  @default(now())
  consecutiveFailures    Int       @default(0)
  etag                   String?
  lastModified           String?
  refreshIntervalMinutes Int       @default(60)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  subscriptions PodcastSubscription[]
  episodes      PodcastEpisode[]

  @@index([nextFetchAt, id])
}

model PodcastSubscription {
  id           String   @id @default(cuid())
  userId       String
  podcastId    String
  customTitle  String?
  sortOrder    Int      @default(0)
  isMuted      Boolean  @default(false)
  isPaused     Boolean  @default(false)
  subscribedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([userId, sortOrder])
}

model PodcastEpisode {
  id               String    @id @default(cuid())
  podcastId        String
  externalId       String
  title            String
  url              String?
  description      String?
  contentHtml      String?
  contentText      String?
  audioUrl         String
  audioType        String?
  audioLengthBytes BigInt?
  durationSeconds  Int?
  imageUrl         String?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  podcast         Podcast                 @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  states          PodcastEpisodeState[]
  collectionItems ArticleCollectionItem[]

  @@unique([podcastId, externalId])
  @@index([podcastId, publishedAt])
}

model PodcastEpisodeState {
  id                      String    @id @default(cuid())
  userId                  String
  episodeId               String
  isPlayed                Boolean   @default(false)
  isStarred               Boolean   @default(false)
  playbackPositionSeconds Int       @default(0)
  playedAt                DateTime?
  starredAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId, isPlayed])
  @@index([userId, isStarred])
}

model Article {
  id           String    @id @default(cuid())
  feedId       String
  externalId   String
  title        String
  url          String
  canonicalUrl String?
  author       String?
  summary      String?
  contentHtml  String?
  contentText  String?
  imageUrl     String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  feed             Feed                    @relation(fields: [feedId], references: [id], onDelete: Cascade)
  states           ArticleState[]
  collectionItems  ArticleCollectionItem[]
  aiSummaries      ArticleAiSummary[]
  aiDigestItems    AiDigestItem[]
  smartDigestItems SmartDigestItem[]

  @@unique([feedId, externalId])
  @@index([feedId, publishedAt])
}

model ArticleState {
  id         String    @id @default(cuid())
  userId     String
  articleId  String
  isRead     Boolean   @default(false)
  isStarred  Boolean   @default(false)
  readAt     DateTime?
  starredAt  DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId, isRead])
  @@index([userId, isStarred])
}

model BulkReadJob {
  id                String            @id @default(cuid())
  userId            String
  scopeType         String
  feedId            String?
  folderId          String?
  status            BulkReadJobStatus @default(QUEUED)
  totalArticles     Int
  processedArticles Int               @default(0)
  markedArticles    Int               @default(0)
  lastArticleId     String?
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  canceledAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
  @@index([status, updatedAt])
}

model ArticleCollection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ArticleCollectionItem[]

  @@unique([userId, name])
  @@index([userId, sortOrder])
}

model ArticleCollectionItem {
  id               String   @id @default(cuid())
  collectionId     String
  articleId        String?
  podcastEpisodeId String?
  createdAt        DateTime @default(now())

  collection     ArticleCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  article        Article?          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  podcastEpisode PodcastEpisode?   @relation(fields: [podcastEpisodeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, articleId])
  @@unique([collectionId, podcastEpisodeId])
  @@index([articleId])
  @@index([podcastEpisodeId])
}

model ArticleAiSummary {
  id                 String   @id @default(cuid())
  articleId          String
  provider           String
  model              String
  shortSummary       String
  bulletSummary      Json?
  keyTakeaway        String?
  category           String?
  sentiment          String?
  readingTimeSeconds Int?
  tokenCount         Int?
  costEstimate       Decimal? @db.Decimal(10, 6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, provider, model])
}

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  action       AiAction
  provider     String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costEstimate Decimal? @db.Decimal(10, 6)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AiUsagePeriod {
  id            String   @id @default(cuid())
  userId        String
  periodStart   DateTime
  limitUnits    Int
  reservedUnits Int      @default(0)
  consumedUnits Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  operations AiOperation[]

  @@unique([userId, periodStart])
  @@index([periodStart])
}

model AiOperation {
  id                String            @id @default(cuid())
  idempotencyKey    String            @unique
  userId            String
  periodId          String?
  action            AiAction
  status            AiOperationStatus @default(RESERVED)
  reservedUnits     Int               @default(0)
  consumedUnits     Int               @default(0)
  provider          String?
  model             String?
  providerRequestId String?
  errorCode         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  completedAt       DateTime?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  period AiUsagePeriod? @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([periodId, status])
}

model AiDigest {
  id           String         @id @default(cuid())
  userId       String
  status       AiDigestStatus @default(PENDING)
  title        String?
  overview     String?
  provider     String?
  model        String?
  articleCount Int            @default(0)
  inputTokens  Int            @default(0)
  outputTokens Int            @default(0)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items AiDigestItem[]

  @@index([userId, createdAt])
  @@index([userId, status])
}

model AiDigestItem {
  id           String          @id @default(cuid())
  digestId     String
  articleId    String?
  section      AiDigestSection
  topic        String
  position     Int
  articleTitle String
  articleUrl   String
  feedTitle    String
  summary      String
  reason       String?
  publishedAt  DateTime?
  createdAt    DateTime        @default(now())

  digest  AiDigest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@unique([digestId, articleId])
  @@index([digestId, section, position])
}

model SmartDigestRule {
  id            String                  @id @default(cuid())
  userId        String
  name          String
  topicPrompt   String
  matchingMode  SmartDigestMatchingMode @default(RULES)
  includeTerms  String[]                @default([])
  excludeTerms  String[]                @default([])
  sourceScope   SmartDigestSourceScope  @default(ALL_FEEDS)
  emailEnabled  Boolean                 @default(false)
  cadence       SmartDigestCadence      @default(DAILY)
  scheduledHour Int                     @default(8)
  timeZone      String                  @default("UTC")
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  lastMatchedAt DateTime?
  contentWatermarkAt DateTime?
  isEnabled     Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders       SmartDigestRuleFolder[]
  subscriptions SmartDigestRuleSubscription[]
  digests       SmartDigest[]
  digestRuns    DigestRun[]

  @@unique([userId, id])
  @@index([userId, isEnabled])
  @@index([isEnabled, nextRunAt])
}

model DigestRun {
  id                  String          @id @default(cuid())
  ruleId              String
  scheduledFor        DateTime
  status              DigestRunStatus @default(PENDING)
  processingStartedAt DateTime?
  completedAt         DateTime?
  watermarkFrom       DateTime?
  watermarkTo         DateTime?
  digestId            String?         @unique
  emailStatus         String?         @default("NOT_REQUESTED")
  providerMessageId   String?
  emailAttemptedAt    DateTime?
  emailDeliveredAt    DateTime?
  emailAttempts       Int             @default(0)
  emailErrorMessage   String?
  errorMessage        String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  rule   SmartDigestRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  digest SmartDigest?    @relation("DigestRunDigest", fields: [digestId], references: [id], onDelete: SetNull)

  @@unique([ruleId, scheduledFor])
  @@index([status, processingStartedAt])
  @@index([emailStatus, createdAt])
}

model SmartDigestRuleFolder {
  id        String   @id @default(cuid())
  userId    String
  ruleId    String
  folderId  String
  createdAt DateTime @default(now())

  rule   SmartDigestRule @relation(fields: [userId, ruleId], references: [userId, id], onDelete: Cascade)
  folder Folder          @relation(fields: [userId, folderId], references: [userId, id], onDelete: Cascade)

  @@unique([ruleId, folderId])
  @@index([folderId])
}

model SmartDigestRuleSubscription {
  id             String   @id @default(cuid())
  userId         String
  ruleId         String
  subscriptionId String
  createdAt      DateTime @default(now())

  rule         SmartDigestRule  @relation(fields: [userId, ruleId], references: [userId, id], onDelete: Cascade)
  subscription FeedSubscription @relation(fields: [userId, subscriptionId], references: [userId, id], onDelete: Cascade)

  @@unique([ruleId, subscriptionId])
  @@index([subscriptionId])
}

model SmartDigest {
  id                String                 @id @default(cuid())
  userId            String
  ruleId            String
  status            SmartDigestStatus      @default(PENDING)
  emailStatus       SmartDigestEmailStatus @default(NOT_REQUESTED)
  title             String
  topicPrompt       String
  articleCount      Int                    @default(0)
  errorMessage      String?
  emailErrorMessage String?
  startedAt         DateTime?
  completedAt       DateTime?
  emailedAt         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule  SmartDigestRule   @relation(fields: [userId, ruleId], references: [userId, id], onDelete: Cascade)
  items SmartDigestItem[]
  digestRun DigestRun?    @relation("DigestRunDigest")

  @@index([userId, createdAt])
  @@index([ruleId, createdAt])
  @@index([status, createdAt])
  @@index([emailStatus, createdAt])
}

model SmartDigestItem {
  id            String    @id @default(cuid())
  digestId      String
  articleId     String?
  articleTitle  String
  articleUrl    String
  feedTitle     String
  summary       String
  matchedTerms  String[]  @default([])
  matchedFields String[]  @default([])
  reason        String
  position      Int
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())

  digest  SmartDigest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  article Article?    @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@unique([digestId, articleId])
  @@unique([digestId, position])
  @@index([articleId])
}

model ImportJob {
  id                String       @id @default(cuid())
  userId            String
  status            ImportStatus @default(PENDING)
  totalFeeds        Int          @default(0)
  processedFeeds    Int          @default(0)
  addedFeeds        Int          @default(0)
  skippedFeeds      Int          @default(0)
  failedFeeds       Int          @default(0)
  folderCount       Int          @default(0)
  cancelRequestedAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  errorLog          Json?
  lastError         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries ImportJobEntry[]

  @@index([userId, status, updatedAt])
  @@index([status, updatedAt])
}

model ImportJobEntry {
  id           String            @id @default(cuid())
  importJobId  String
  sequence     Int
  folderName   String?
  title        String
  xmlUrl       String
  status       ImportEntryStatus @default(PENDING)
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@unique([importJobId, sequence])
  @@index([importJobId, status, sequence])
}

model BugReport {
  id           String   @id @default(cuid())
  userId       String?
  title        String
  description  String
  pageUrl      String?
  userAgent    String?
  contactEmail String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model FeatureSuggestion {
  id           String   @id @default(cuid())
  userId       String?
  title        String
  description  String
  pageUrl      String?
  userAgent    String?
  contactEmail String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model DiscoverCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  description String
  countryCode String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  feeds DiscoverFeed[]

  @@index([countryCode, sortOrder])
  @@index([sortOrder])
}

model DiscoverFeed {
  id         String   @id @default(cuid())
  categoryId String
  slug       String   @unique
  label      String
  source     String
  url        String
  aliases    String[] @default([])
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category DiscoverCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, sortOrder])
}

model DiscoverCategoryCustomization {
  id           String   @id @default(cuid())
  categorySlug String   @unique
  description  String?
  iconKey      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([categorySlug])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String?
  actorUserId String?
  actorEmail  String?
  actorName   String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser User? @relation("AdminAuditActor", fields: [adminUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@index([adminUserId, createdAt])
}
