generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ADMIN
}

enum DefaultView {
  CLASSIC
  CARD
  COMPACT
  RIVER
}

enum ThemePreference {
  SYSTEM
  LIGHT
  DARK
}

enum FontSizePreference {
  SMALL
  MEDIUM
  LARGE
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiAction {
  ARTICLE_SUMMARY
  DAILY_DIGEST
  EXPLAIN_ARTICLE
  SMART_CATEGORY
  SEARCH
}

enum AiDigestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiDigestSection {
  MUST_READ
  SKIM_LATER
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  passwordHash   String?
  role           Role      @default(USER)
  plan           Plan      @default(FREE)
  aiMonthlyLimit Int       @default(100)
  aiMonthlyUsed  Int       @default(0)
  disabledAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  settings       UserSettings?
  folders        Folder[]
  subscriptions  FeedSubscription[]
  articleStates  ArticleState[]
  aiUsageLogs    AiUsageLog[]
  aiDigests      AiDigest[]
  importJobs     ImportJob[]
  adminAuditLogs AdminAuditLog[]    @relation("AdminAuditActor")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model UserSettings {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  defaultView            DefaultView        @default(CLASSIC)
  theme                  ThemePreference    @default(SYSTEM)
  fontSize               FontSizePreference @default(MEDIUM)
  markReadOnOpen         Boolean            @default(true)
  openLinksInNewTab      Boolean            @default(true)
  aiAutoSummariesEnabled Boolean            @default(false)
  dailyDigestEnabled     Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions FeedSubscription[]

  @@index([userId, sortOrder])
}

model Feed {
  id                     String    @id @default(cuid())
  feedUrl                String    @unique
  siteUrl                String?
  title                  String
  description            String?
  faviconUrl             String?
  language               String?
  lastFetchedAt          DateTime?
  lastSuccessfulFetchAt  DateTime?
  lastFailedAt           DateTime?
  lastError              String?
  etag                   String?
  lastModified           String?
  refreshIntervalMinutes Int       @default(60)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  subscriptions FeedSubscription[]
  articles      Article[]
}

model FeedSubscription {
  id           String   @id @default(cuid())
  userId       String
  feedId       String
  folderId     String?
  customTitle  String?
  sortOrder    Int      @default(0)
  isMuted      Boolean  @default(false)
  isPaused     Boolean  @default(false)
  subscribedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  feed   Feed    @relation(fields: [feedId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([userId, feedId])
  @@index([userId, folderId])
}

model Article {
  id           String    @id @default(cuid())
  feedId       String
  externalId   String
  title        String
  url          String
  canonicalUrl String?
  author       String?
  summary      String?
  contentHtml  String?
  contentText  String?
  imageUrl     String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  feed          Feed               @relation(fields: [feedId], references: [id], onDelete: Cascade)
  states        ArticleState[]
  aiSummaries   ArticleAiSummary[]
  aiDigestItems AiDigestItem[]

  @@unique([feedId, externalId])
  @@index([feedId, publishedAt])
}

model ArticleState {
  id         String    @id @default(cuid())
  userId     String
  articleId  String
  isRead     Boolean   @default(false)
  isStarred  Boolean   @default(false)
  readAt     DateTime?
  starredAt  DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId, isRead])
  @@index([userId, isStarred])
}

model ArticleAiSummary {
  id                 String   @id @default(cuid())
  articleId          String
  provider           String
  model              String
  shortSummary       String
  bulletSummary      Json?
  keyTakeaway        String?
  category           String?
  sentiment          String?
  readingTimeSeconds Int?
  tokenCount         Int?
  costEstimate       Decimal? @db.Decimal(10, 6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, provider, model])
}

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  action       AiAction
  provider     String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costEstimate Decimal? @db.Decimal(10, 6)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AiDigest {
  id           String         @id @default(cuid())
  userId       String
  status       AiDigestStatus @default(PENDING)
  title        String?
  overview     String?
  provider     String?
  model        String?
  articleCount Int            @default(0)
  inputTokens  Int            @default(0)
  outputTokens Int            @default(0)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items AiDigestItem[]

  @@index([userId, createdAt])
  @@index([userId, status])
}

model AiDigestItem {
  id           String          @id @default(cuid())
  digestId     String
  articleId    String?
  section      AiDigestSection
  topic        String
  position     Int
  articleTitle String
  articleUrl   String
  feedTitle    String
  summary      String
  reason       String?
  publishedAt  DateTime?
  createdAt    DateTime        @default(now())

  digest  AiDigest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@unique([digestId, articleId])
  @@index([digestId, section, position])
}

model ImportJob {
  id           String       @id @default(cuid())
  userId       String
  status       ImportStatus @default(PENDING)
  totalFeeds   Int          @default(0)
  addedFeeds   Int          @default(0)
  skippedFeeds Int          @default(0)
  failedFeeds  Int          @default(0)
  errorLog     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser User @relation("AdminAuditActor", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
}
