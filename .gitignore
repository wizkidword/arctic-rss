# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/output/playwright/
/.playwright-cli/

# generated
/src/generated/prisma

# next.js
/.next/
/out/

# production
/build
/.worktrees
/marketing/product-hunt/raw/*
!/marketing/product-hunt/raw/README.md

# local agent workspace state
/.agents/
/.codex/
/.superpowers/

# private release-operator configuration
/scripts/windows/release-config.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
