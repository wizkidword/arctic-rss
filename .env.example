# Safe development template for Arctic RSS.
# Copy this file to .env and replace every CHANGE_ME value before use.
# Never copy the production .env into a workstation or commit it.
#
# These connection URLs use Docker Compose service names. When running `npm run dev`
# directly on the host, change `postgres` and `redis` to `localhost`.

# PostgreSQL and Redis
POSTGRES_DB=arctic_rss
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DATABASE_PASSWORD
DATABASE_URL=postgresql://postgres:CHANGE_ME_LOCAL_DATABASE_PASSWORD@postgres:5432/arctic_rss?schema=public
REDIS_URL=redis://redis:6379
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Auth and application URLs
AUTH_SECRET=CHANGE_ME_GENERATE_A_32_BYTE_SECRET
# The one canonical browser-facing origin. Production must use HTTPS.
APP_ORIGIN=http://localhost:3000
# Optional comma-separated host aliases that should redirect to APP_ORIGIN.
APP_ALLOWED_HOSTS=
# Auth.js requires this flag; host acceptance is enforced by src/proxy.ts.
AUTH_TRUST_HOST=true
# Must exactly match APP_ORIGIN in production so Auth.js cannot derive URLs
# from request headers. NEXTAUTH_URL and NEXT_PUBLIC_APP_URL are legacy-only.
AUTH_URL=http://localhost:3000
REQUIRE_EMAIL_VERIFICATION=true
CRON_SECRET=CHANGE_ME_GENERATE_A_SEPARATE_SECRET

# Optional Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional transactional email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Arctic RSS <no-reply@example.com>

# Optional Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Set true only after both Turnstile keys are configured for APP_ORIGIN's host.
# Production startup intentionally fails when this is true but either key is absent.
TURNSTILE_REQUIRED=false

# Optional Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional OpenAI-powered summaries and digests. Leave AI_PROVIDER empty for the
# built-in deterministic provider used in local development.
AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=
OPENAI_SUMMARY_MODEL=
AI_DIGEST_MODEL=
AI_DIGEST_CONCURRENCY=2
SMART_DIGEST_CONCURRENCY=2

# Background refresh tuning
FEED_REFRESH_CONCURRENCY=5
FEED_SCHEDULER_BATCH_SIZE=50
FEED_SCHEDULER_INTERVAL_MS=60000
AUTH_TOKEN_MAINTENANCE_BATCH_SIZE=100
AUTH_TOKEN_MAINTENANCE_INTERVAL_MS=900000
PODCAST_REFRESH_CONCURRENCY=3

# Optional Docker Compose Cloudflare Tunnel profile. The Hetzner production
# connector is managed separately, so leave this empty unless intentionally
# changing the routing architecture.
CLOUDFLARE_TUNNEL_TOKEN=
