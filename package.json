{
  "name": "arctic-rss",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "chat:bootstrap": "tsx scripts/bootstrap-chat-rooms.ts",
    "chat:beta": "tsx scripts/manage-chat-beta-access.ts",
    "chat:load-test": "tsx scripts/load-test-chat-gateway.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "ph:assets": "tsx scripts/product-hunt/capture-assets.ts && tsx scripts/product-hunt/render-assets.ts && tsx scripts/product-hunt/validate-assets.ts",
    "ph:assets:validate": "tsx scripts/product-hunt/validate-assets.ts",
    "ph:audit": "tsx scripts/product-hunt/launch-readiness.ts",
    "ph:demo": "tsx scripts/product-hunt/record-demo.ts",
    "ph:metrics": "tsx scripts/product-hunt/collect-internal-metrics.ts",
    "ph:package": "npm run ph:test && npm run ph:audit -- --strict && npm run ph:assets:validate",
    "ph:smoke": "tsx scripts/product-hunt/launch-smoke-test.ts",
    "ph:test": "vitest run src/lib/articles.test.ts src/app/layout.test.tsx src/app/page.test.tsx",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "worker": "tsx worker/index.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.3",
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.10.1",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.11",
    "next-auth": "^5.0.0-beta.32",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.5",
    "shadcn": "^4.11.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "undici": "7.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "@ts-morph/common": {
      "brace-expansion": "5.0.8"
    },
    "fast-uri": "3.1.4",
    "js-yaml": "4.3.0",
    "postcss": "8.5.15",
    "sharp": "0.35.0"
  }
}
